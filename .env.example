DATABASE_URL=postgres://beacon:beacon@127.0.0.1:5432/beacon
FRONTEND_URL=http://localhost:3001

# Set to true when using https so the cookie is secure
COOKIE_SECURE=false

# Base URL
OAUTH_REDIRECT_BASE=http://localhost:3000

# GitHub OAuth app credentials (https://github.com/settings/developers)
# Authorization callback URL: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord OAuth app credentials (https://discord.com/developers/applications)
# Redirect URL: http://localhost:3000/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Cloudflare Turnstile secret for the register form (https://dash.cloudflare.com/?to=/:account/turnstile)
# Leave empty to disable the captcha. Dev test key (always passes): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET=
